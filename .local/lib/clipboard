# vim: ft=bash
# Bash library to help unify logs accross scripts
#
function clip_paste() {
  case "$(uname -s)" in

  "Darwin")
    pbpaste
    ;;

  "Linux")
    session_type="$(loginctl show-session $(loginctl | grep $(whoami) | awk '{print $1}') -p Type | awk -F "=" '{print $2}')"
    if [[ "${session_type}" == "wayland" ]]; then
      wl-paste
    else
      xclip -o
    fi
    ;;

  esac
}
