#!/usr/bin/env bash

# lists available projects
#
# This will list all projects for a given organization

source "${HOME}/.local/lib/log"

ACTIVE_ORGANIZATION="$(cat ${HOME}/.cache/project/organization 2>/dev/null)"
projects_archive=${PROJECTS_ARCHIVE:-${HOME}/work/${ACTIVE_ORGANIZATION}}
projects_path=${PROJECTS_PATH:-${HOME}/projects/${ACTIVE_ORGANIZATION}}

if [ -n "${ACTIVE_ORGANIZATION}" ]; then
  tree "${projects_path}" -dL 1
  tree "${projects_archive}" -dL 1
else
  log_error "project" "no organization has been set"
fi
